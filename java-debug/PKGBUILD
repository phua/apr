pkgver() {
    curl --silent --location https://repo1.maven.org/maven2/com/microsoft/java/com.microsoft.java.debug.plugin/maven-metadata.xml | xmllint --xpath '/metadata/versioning/latest/text()' -
}

package() {
    install -D --target-directory "${pkgdir}/usr/share/java/${pkgname}" --mode 644 "${srcdir}/com.microsoft.java.debug.plugin-${pkgver}.jar"
}
